rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────

    function uid() {
      return request.auth.uid;
    }

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid())).data.role == "admin";
    }

    // RT é dono da clínica se tenantId == uid dele
    function isTenant(tenantId) {
      return isAuth() && uid() == tenantId;
    }

    // Documento sendo criado tem tenantId == uid de quem cria
    function criaComTenantCorreto() {
      return request.resource.data.tenantId == uid();
    }

    // Plano do RT que está fazendo a requisição
    function profile() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function plano() {
      return profile().plan;
    }

    // RT tem plano ativo (core ou pro) ou trial ativo
    function temPlanoAtivo() {
      return isAuth() && (plano() in ["core", "pro"] || profile().trialActive == true);
    }

    // ── Usuários ─────────────────────────────────────────────

    match /users/{userId} {
      allow read: if uid() == userId || isAdmin();
      allow create: if isAuth() && uid() == userId;
      allow update: if (uid() == userId || isAdmin())
        && (isAdmin() || !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['plan', 'plano', 'planoExpiraEm', 'planoAtivadoEm', 'hotmartPedidoId', 'passConvertido']));
      allow delete: if false;
    }

    match /usuarios/{userId} {
      allow read: if uid() == userId || isAdmin();
      allow create: if isAuth() && uid() == userId;
      allow update: if (uid() == userId || isAdmin())
        && (isAdmin() || !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['plan', 'plano', 'planoExpiraEm', 'planoAtivadoEm', 'hotmartPedidoId', 'passConvertido']));
      allow delete: if false;
    }

    // ── Clínicas ─────────────────────────────────────────────

    match /clinicas/{clinicaId} {
      allow read: if isTenant(resource.data.tenantId) || isAdmin();
      allow create: if isAuth() && criaComTenantCorreto();
      allow update, delete: if isTenant(resource.data.tenantId) || isAdmin();

      // Subcoleções (Vistorias, Diagnósticos, etc) - Permite se o usuário é o dono da clínica pai
      match /{allSubcollections=**} {
        allow read, write: if isTenant(get(/databases/$(database)/documents/clinicas/$(clinicaId)).data.tenantId) || isAdmin();
      }
    }

    // ── Cronogramas de Conformidade (Flight Plans 5W2H) ──────
    match /flightPlans/{clinicaId} {
      allow read, write: if isTenant(get(/databases/$(database)/documents/clinicas/$(clinicaId)).data.tenantId) || isAdmin();
    }

    // ── Coleções Operacionais (Isoladas e Protegidas por Plano) ──

    match /auditorias/{docId} {
      allow read: if isTenant(resource.data.tenantId) || isAdmin();
      allow create: if temPlanoAtivo() && criaComTenantCorreto();
      allow update: if isTenant(resource.data.tenantId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /laudos/{docId} {
      allow read: if isAuth() && (resource.data.userId == uid() || resource.data.tenantId == uid() || isAdmin());
      allow create: if isAuth();
      allow update, delete: if isAuth() && (resource.data.userId == uid() || resource.data.tenantId == uid() || isAdmin());
    }

    match /notificacoes/{docId} {
      allow read: if isAuth() && (resource.data.tenantId == uid() || resource.data.clinicaId == uid() || isAdmin());
      allow create, update: if isAdmin(); // Notificações são geradas pelo sistema
      allow delete: if isAdmin();
    }

    match /rotinas_diarias/{docId} {
      allow read: if isTenant(resource.data.tenantId) || isAdmin();
      allow create: if isAuth();
      allow update, delete: if isTenant(resource.data.tenantId) || isAdmin();
    }

    match /cronogramas_mensais/{docId} {
      allow read: if isAuth() && (resource == null || isTenant(resource.data.tenantId) || isAdmin());
      allow create: if isAuth() && (request.resource.data.tenantId == uid() || isAdmin());
      allow update: if isTenant(resource.data.tenantId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /gtas/{userId}/{document=**} {
      allow read, write: if uid() == userId || isAdmin();
    }

    match /controlados/{userId}/{document=**} {
      allow read, write: if uid() == userId || isAdmin();
    }

    match /template/{docId} {
      allow read: if isAuth(); // Qualquer RT logado lê templates
      allow write: if isAdmin();
    }

    // Pendentes da Hotmart: Protegido
    match /hotmart_pendentes/{docId} {
      allow read, write: if false; // Só acessível via Admin SDK (Cloud Functions)
    }
    match /pagamentosPendentes/{docId} {
      allow read, write: if false; // Só acessível via Admin SDK (Cloud Functions)
    }
    match /erros_app/{docId} {
      allow create: if true;
    }
  }
}
